{
  "name": "@neabyte/trustless-id",
  "version": "0.1.0",
  "description": "Time-bound anonymous ID: request, decode, verify. No server",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "unbuild --minify",
    "clean": "rm -rf dist",
    "prepublishOnly": "rm -rf dist && npm run build"
  },
  "keywords": [
    "anonymous-id",
    "client-side",
    "connector",
    "deno",
    "esm",
    "handshake",
    "javascript",
    "library",
    "no-server",
    "nodejs",
    "one-time-code",
    "pairing",
    "session-id",
    "time-bound",
    "trustless",
    "typescript",
    "verification",
    "verification-code",
    "zero-dependency"
  ],
  "dependencies": {},
  "devDependencies": {
    "unbuild": "^3.6.1"
  },
  "author": {
    "name": "NeaByteLab",
    "email": "me@neabyte.com",
    "url": "https://github.com/NeaByteLab"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeaByteLab/Trustless-ID.git"
  },
  "bugs": {
    "url": "https://github.com/NeaByteLab/Trustless-ID/issues"
  },
  "homepage": "https://github.com/NeaByteLab/Trustless-ID#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
